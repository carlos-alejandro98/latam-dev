{
  "expo": {
    "name": "AptoTatGantt",
    "slug": "AptoTatGantt",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./presentation/assets/images/icon.png",
    "scheme": "compass",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appslatam.compass"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./presentation/assets/images/android-icon-background.png",
        "backgroundImage": "./presentation/assets/images/android-icon-background.png",
        "monochromeImage": "./presentation/assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.appslatam.compass"
    },
    "web": {
      "output": "static",
      "favicon": "./presentation/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./presentation/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "autolinking": {
      "exclude": ["expo-image"]
    }
  }
}
