apiVersion: apps/v1
kind: Deployment
metadata:
  name: "<%= owner_name %>-<%= repository_name %>"
  labels:
    app: "<%= owner_name %>"
    git_commit: "<%= git_commit %>"
    build_id: "<%= build_id %>"
    cmdb_<%= cmdb_it_element %>: "<%= cmdb_it_element %>"
spec:
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 10
      maxUnavailable: 0
  selector:
    matchLabels:
      pod: "<%= repository_name %>"
  progressDeadlineSeconds: 600
  template:
    metadata:
      name: "<%= owner_name %>-<%= repository_name %>"
      labels:
        app: "<%= owner_name %>"
        git_commit: "<%= git_commit %>"
        build_id: "<%= build_id %>"
        pod: "<%= repository_name %>"
    spec:
      serviceAccountName: "ganttdinamica-<%= environment %>-sa"
      containers:
        - name: app
          image: "<%= docker_image %>"
          resources:
            requests:
              memory: "<%= app_memory %>"
              cpu: "<%= app_cpu %>"
              ephemeral-storage: "<%= app_ephemeral_storage %>"
          imagePullPolicy: IfNotPresent
---
apiVersion: cloud.google.com/v1
kind: BackendConfig
metadata:
  namespace: "<%= namespace %>"
  name: <%= owner_name %>-<%= environment %>-<%= repository_name %>-backendconfig
  labels:
    app: "<%= owner_name %>"
spec:
  timeoutSec: 600
  securityPolicy:
    name: "cloudarmor-corp"
  healthCheck:
    checkIntervalSec: 120
    type: HTTP
    requestPath: "/"
    port: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: "<%= owner_name %>-<%= repository_name %>-service"
  labels:
    app: "<%= owner_name %>"
  annotations:
    cloud.google.com/neg: '{"ingress": true}'
    cloud.google.com/backend-config: '{ "ports": { "80" : "<%= owner_name %>-<%= environment %>-<%= repository_name %>-backendconfig" } }'
spec:
  ports:
    - name: http
      port: 80
      protocol: TCP
      targetPort: 8080
  selector:
    pod: "<%= repository_name %>"
  type: NodePort
---
