{
  "name": "aptotatgantt",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node -r ./scripts/array-polyfills.js ./node_modules/.bin/expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "node -r ./scripts/array-polyfills.js ./node_modules/.bin/expo start --android",
    "ios": "node -r ./scripts/array-polyfills.js ./node_modules/.bin/expo start --ios",
    "web": "node -r ./scripts/array-polyfills.js ./node_modules/.bin/expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "node scripts/setup-env.js",
    "setup:env": "node scripts/setup-env.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "export:web": "expo export --platform web",
    "ds": "tsx scripts/design-system/cli/index.ts",
    "ds:build": "npm run ds build",
    "ds:verify": "npm run ds verify",
    "ds:props": "npm run ds props",
    "sonar": "npx @sonar/scan",
    "build": "./scripts/create-env.sh && expo export --platform web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hangar/mobile-components": "^2.2.0",
    "@hangar/react-icons": "^1.10.1",
    "@hangar/react-native-icons": "^1.10.1",
    "@hangar/web-components": "^1.7.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.31",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/utils": "^8.56.0",
    "@visx/scale": "^3.12.0",
    "axios": "^1.13.5",
    "esbuild": "^0.27.3",
    "expo": "~54.0.32",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.22",
    "expo-secure-store": "^55.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "glob": "^13.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^4.2.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "react-window": "^2.2.7",
    "styled-components": "^6.3.8",
    "ts-jest": "^29.4.6",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.54.0"
  },
  "resolutions": {
    "@hangar/themes": "*"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-image"
      ]
    }
  },
  "private": true
